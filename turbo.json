{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": ["NODE_ENV", "PORT", "DATABASE_URL", "JWT_SECRET", "API_URL", "VITE_API_URL"],
  "tasks": {
    "format": { "dependsOn": [], "outputs": [] },
    "clean": { "cache": false },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"],
      "env": ["NODE_ENV", "API_URL", "VITE_API_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "generate": {
      "cache": false,
      "dependsOn": [],
      "outputs": ["node_modules/.prisma/**", "src/generated/**"]
    },
    "@repo/api#dev": {
      "cache": false,
      "persistent": true,
      "env": ["PORT", "DATABASE_URL", "JWT_SECRET"]
    },
    "@repo/api#build": {
      "dependsOn": ["^build", "@repo/api#generate"],
      "outputs": ["dist/**"]
    },
    "@repo/api#generate": {
      "cache": false,
      "outputs": ["node_modules/.prisma/**", "src/generated/**"]
    },
    "@repo/api#migrate:dev": {
      "cache": false,
      "dependsOn": ["@repo/api#generate"]
    },
    "@repo/api#db:studio": {
      "cache": false,
      "persistent": true
    },
    "@repo/web#dev": {
      "cache": false,
      "persistent": true,
      "env": ["VITE_API_URL"]
    },
    "@repo/web#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["VITE_API_URL"]
    }
  }
}
